<Page
    x:Class="Radar.App.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Radar.App.Pages"
    xmlns:controls="using:Radar.App.Controls">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="1100" HorizontalAlignment="Stretch">
            <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- Cartões-resumo -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock x:Name="CardNewProcs" Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock x:Name="CardNewProcsLabel" Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock x:Name="CardShortLived" Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock x:Name="CardShortLivedLabel" Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock x:Name="CardPersistence" Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock x:Name="CardPersistenceLabel" Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock x:Name="CardUpload" Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock x:Name="CardUploadLabel" Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="16">
                    <!-- Achados recentes em linguagem natural -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="FindingsTitle" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <ItemsControl x:Name="FindingsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:FindingCard">
                                        <Grid Padding="0,6" ColumnSpacing="10" Tapped="Finding_Tapped"
                                              Background="Transparent" Tag="{x:Bind ExecutionId}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="10" Height="10" CornerRadius="5"
                                                    VerticalAlignment="Top" Margin="0,6,0,0"
                                                    Background="{x:Bind BandBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Text}" TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoFindings" Opacity="0.6" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- Top por score -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="TopTitle" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <ItemsControl x:Name="TopList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:TopRow">
                                        <Grid Padding="0,4" ColumnSpacing="10" Tapped="Finding_Tapped"
                                              Background="Transparent" Tag="{x:Bind ExecutionId}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{x:Bind BandBrush}" CornerRadius="4" Padding="6,2"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{x:Bind Score}" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{x:Bind Detail}" Opacity="0.65" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{x:Bind When}" Opacity="0.6" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="16">
                    <!-- Saúde da coleta -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="HealthTitle" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:Name="HealthStatus" TextWrapping="Wrap"/>
                            <TextBlock x:Name="HealthDetail" Opacity="0.7" TextWrapping="Wrap" FontSize="12"/>
                            <TextBlock x:Name="HealthModules" Opacity="0.7" TextWrapping="Wrap" FontSize="12"/>
                            <Button x:Name="StartCollectorButton" Click="StartCollector_Click" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- Atividade por dia -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="ChartTitle" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <controls:MiniBarChart x:Name="ActivityChart" Height="180"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
