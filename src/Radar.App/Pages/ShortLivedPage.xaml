<Page
    x:Class="Radar.App.Pages.ShortLivedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Radar.App.Pages"
    xmlns:loc="using:Radar.App.Services">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="16">
            <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}"/>
            <InfoBadge x:Name="CountBadge" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <ComboBox x:Name="SortCombo" Header="{loc:Loc Key=Ordenar por}" SelectedIndex="0" SelectionChanged="Filters_Changed">
                <ComboBoxItem Content="Score"/>
                <ComboBoxItem Content="{loc:Loc Key=Recência}"/>
                <ComboBoxItem Content="{loc:Loc Key=Volume de rede}"/>
                <ComboBoxItem Content="{loc:Loc Key=Repetições}"/>
            </ComboBox>
            <ComboBox x:Name="PeriodCombo" Header="{loc:Loc Key=Período}" SelectedIndex="1" SelectionChanged="Filters_Changed">
                <ComboBoxItem Content="{loc:Loc Key=24 horas}"/>
                <ComboBoxItem Content="{loc:Loc Key=7 dias}"/>
                <ComboBoxItem Content="{loc:Loc Key=30 dias}"/>
            </ComboBox>
            <ToggleSwitch x:Name="ShowSuppressed" Header="{loc:Loc Key=Mostrar suprimidos}" Toggled="Filters_Changed"/>
            <TextBlock x:Name="SuppressedText" VerticalAlignment="Bottom" Opacity="0.65" Margin="0,0,0,8"/>
        </StackPanel>

        <ListView x:Name="GroupsList" Grid.Row="2" SelectionMode="None" IsItemClickEnabled="False">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ShortLivedGroupRow">
                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,2">
                        <Expander.Header>
                            <Grid ColumnSpacing="12" Padding="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{x:Bind BandBrush}" CornerRadius="4" Padding="6,2"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind MaxScore}" Foreground="White" FontWeight="Bold"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind RegularityWarning}" Foreground="#986F0B" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Path}" Opacity="0.65" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{x:Bind Stats}" Opacity="0.7" FontSize="12"
                                           VerticalAlignment="Center" TextAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind LastSeen}" Opacity="0.6" FontSize="12"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </Expander.Header>
                        <ItemsControl ItemsSource="{x:Bind Executions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:ShortLivedExecRow">
                                    <Grid ColumnSpacing="12" Padding="8,6" Background="Transparent"
                                          Tapped="Execution_Tapped" Tag="{x:Bind ExecutionId}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind When}" FontSize="12" Opacity="0.8"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Duration}" FontSize="12"
                                                   Foreground="{x:Bind DurationBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{x:Bind CommandLine}" FontSize="12"
                                                   Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{x:Bind Score}" FontSize="12" FontWeight="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
