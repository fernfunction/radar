<Page
    x:Class="Radar.App.Pages.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Radar.App.Pages"
    xmlns:loc="using:Radar.App.Services">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <ComboBox x:Name="PeriodCombo" Header="{loc:Loc Key=Período}" SelectedIndex="1" SelectionChanged="Filters_Changed">
                <ComboBoxItem Content="{loc:Loc Key=24 horas}"/>
                <ComboBoxItem Content="{loc:Loc Key=7 dias}"/>
                <ComboBoxItem Content="{loc:Loc Key=30 dias}"/>
            </ComboBox>
            <CheckBox x:Name="OnlyDirectIp" Content="{loc:Loc Key=Só IP direto (sem DNS)}" VerticalAlignment="Bottom"
                      Checked="Filters_Changed" Unchecked="Filters_Changed"/>
            <CheckBox x:Name="OnlyUpload" Content="{loc:Loc Key=Upload &gt; download}" VerticalAlignment="Bottom"
                      Checked="Filters_Changed" Unchecked="Filters_Changed"/>
        </StackPanel>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tabela por processo -->
            <ListView x:Name="ConnectionsList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:NetworkRow">
                        <Grid ColumnSpacing="12" Padding="0,5" Background="Transparent"
                              Tapped="Row_Tapped" Tag="{x:Bind ExecutionId}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{x:Bind Process}" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind When}" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{x:Bind Destination}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind DomainInfo}" Opacity="0.65" FontSize="12"
                                           Foreground="{x:Bind DomainBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{x:Bind Traffic}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind Flags}" FontSize="12" Foreground="#CA5010"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Grafo de comunicação compacto: processo → destinos com espessura por volume -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" VerticalAlignment="Top">
                <StackPanel Spacing="8">
                    <TextBlock Text="{loc:Loc Key=Grafo de comunicação}" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <ItemsControl x:Name="GraphList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:GraphRow">
                                <StackPanel Padding="0,4">
                                    <TextBlock Text="{x:Bind Process}" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{x:Bind ScoreBrush}"/>
                                    <ItemsControl ItemsSource="{x:Bind Edges}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:GraphEdge">
                                                <Grid ColumnSpacing="6" Margin="12,1,0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Rectangle Width="{x:Bind Thickness}" Height="3" Fill="#888"
                                                               VerticalAlignment="Center" RadiusX="1.5" RadiusY="1.5"/>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Destination}" FontSize="12"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{x:Bind Volume}" FontSize="11" Opacity="0.6"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
