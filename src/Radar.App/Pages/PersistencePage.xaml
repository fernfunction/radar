<Page
    x:Class="Radar.App.Pages.PersistencePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Radar.App.Pages"
    xmlns:loc="using:Radar.App.Services">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <ComboBox x:Name="ViewCombo" Header="{loc:Loc Key=Visão}" SelectedIndex="0" SelectionChanged="Filters_Changed">
                <ComboBoxItem Content="{loc:Loc Key=Diff temporal (o que mudou)}"/>
                <ComboBoxItem Content="{loc:Loc Key=Tudo que está ativo}"/>
            </ComboBox>
            <ComboBox x:Name="PeriodCombo" Header="{loc:Loc Key=Janela do diff}" SelectedIndex="1" SelectionChanged="Filters_Changed">
                <ComboBoxItem Content="{loc:Loc Key=24 horas}"/>
                <ComboBoxItem Content="{loc:Loc Key=7 dias}"/>
                <ComboBoxItem Content="{loc:Loc Key=30 dias}"/>
            </ComboBox>
        </StackPanel>

        <ListView x:Name="EntriesList" Grid.Row="2" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:PersistenceRow">
                    <Grid ColumnSpacing="12" Padding="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{x:Bind ChangeBrush}" CornerRadius="4" Padding="8,3"
                                VerticalAlignment="Top" MinWidth="86">
                            <TextBlock Text="{x:Bind ChangeKind}" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind KindName}" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind Target}" Opacity="0.7" FontSize="12" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind Correlation}" Foreground="#CA5010" FontSize="12" TextWrapping="Wrap"/>
                            <TextBlock Text="{x:Bind Location}" Opacity="0.5" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind When}" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                        <Button Grid.Column="3" Content="{loc:Loc Key=Abrir local}" FontSize="12" Click="OpenLocation_Click"
                                Tag="{x:Bind OpenTarget}" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
