<Page
    x:Class="Radar.App.Pages.SignaturesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Radar.App.Pages"
    xmlns:loc="using:Radar.App.Services">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <ComboBox x:Name="StateCombo" Header="{loc:Loc Key=Estado de assinatura}" SelectedIndex="0" SelectionChanged="Filters_Changed">
                <ComboBoxItem Content="{loc:Loc Key=Todos os dignos de atenção}"/>
                <ComboBoxItem Content="{loc:Loc Key=Assinatura inválida (alterado)}"/>
                <ComboBoxItem Content="{loc:Loc Key=Certificado revogado}"/>
                <ComboBoxItem Content="{loc:Loc Key=Não assinado}"/>
                <ComboBoxItem Content="{loc:Loc Key=Auto-assinado}"/>
                <ComboBoxItem Content="{loc:Loc Key=Com ressalvas}"/>
                <ComboBoxItem Content="{loc:Loc Key=Assinado e confiável}"/>
            </ComboBox>
            <ComboBox x:Name="PeriodCombo" Header="{loc:Loc Key=Período}" SelectedIndex="1" SelectionChanged="Filters_Changed">
                <ComboBoxItem Content="{loc:Loc Key=24 horas}"/>
                <ComboBoxItem Content="{loc:Loc Key=7 dias}"/>
                <ComboBoxItem Content="{loc:Loc Key=30 dias}"/>
            </ComboBox>
        </StackPanel>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListView x:Name="BinariesList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:SignatureRow">
                        <Grid ColumnSpacing="12" Padding="0,6" Background="Transparent"
                              Tapped="Row_Tapped" Tag="{x:Bind ExecutionId}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{x:Bind StateBrush}" CornerRadius="4" Padding="8,3"
                                    VerticalAlignment="Top" MinWidth="150">
                                <TextBlock Text="{x:Bind StateName}" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </Border>
                            <StackPanel Grid.Column="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind MasqueradeWarning}" Foreground="#C50F1F" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind Path}" Opacity="0.65" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind SignerInfo}" Opacity="0.65" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{x:Bind When}" Opacity="0.6" FontSize="12"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Emissores raros na máquina -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" VerticalAlignment="Top">
                <StackPanel Spacing="8">
                    <TextBlock Text="{loc:Loc Key=Emissores raros nesta máquina}" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="{loc:Loc Key=Um certificado de empresa nunca vista assinando algo em %APPDATA% merece nota.}"
                               Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                    <ItemsControl x:Name="RareIssuersList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:RareIssuerRow">
                                <StackPanel Padding="0,4">
                                    <TextBlock Text="{x:Bind Issuer}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap"/>
                                    <TextBlock Text="{x:Bind Detail}" Opacity="0.65" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
