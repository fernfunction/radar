<Page
    x:Class="Radar.App.Pages.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Radar.App.Pages"
    xmlns:loc="using:Radar.App.Services">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}"/>

        <AutoSuggestBox x:Name="SearchBox" Grid.Row="1" QueryIcon="Find"
                        PlaceholderText="{loc:Loc Key='nome, caminho, hash, domínio, IP, emissor de certificado, usuário…'}"
                        QuerySubmitted="Search_Submitted" MaxWidth="700" HorizontalAlignment="Left"/>

        <ListView x:Name="ResultsList" Grid.Row="2" SelectionMode="None" IsItemClickEnabled="True"
                  ItemClick="Result_Clicked">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:SearchRow">
                    <Grid ColumnSpacing="12" Padding="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{x:Bind ScoreBrush}" CornerRadius="4" Padding="6,2"
                                HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Score}" Foreground="White" FontWeight="Bold"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind Detail}" Opacity="0.65" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind When}" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
