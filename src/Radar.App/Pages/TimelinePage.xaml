<Page
    x:Class="Radar.App.Pages.TimelinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Radar.App.Pages"
    xmlns:controls="using:Radar.App.Controls"
    xmlns:loc="using:Radar.App.Services">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <ComboBox x:Name="PeriodCombo" Header="{loc:Loc Key=Período}" SelectedIndex="0" SelectionChanged="Filters_Changed">
                <ComboBoxItem Content="{loc:Loc Key=24 horas}"/>
                <ComboBoxItem Content="{loc:Loc Key=7 dias}"/>
                <ComboBoxItem Content="{loc:Loc Key=30 dias}"/>
            </ComboBox>
            <Slider x:Name="MinScoreSlider" Header="{loc:Loc Key=Score mínimo}" Minimum="0" Maximum="80" StepFrequency="5"
                    Width="200" ValueChanged="Filters_Changed"/>
            <TextBox x:Name="UserFilter" Header="{loc:Loc Key=Usuário/conta}" Width="160" TextChanged="Filters_Changed"/>
            <CheckBox x:Name="OnlyNetworked" Content="{loc:Loc Key=Só com rede}" Checked="Filters_Changed" Unchecked="Filters_Changed"
                      VerticalAlignment="Bottom"/>
        </StackPanel>

        <!-- Densidade de eventos por hora: "o que rodou às 3h da manhã?" -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="8">
            <controls:MiniBarChart x:Name="DensityChart" Height="110"/>
        </Border>

        <ListView x:Name="EventsList" Grid.Row="3" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:TimelineRow">
                    <Grid ColumnSpacing="12" Padding="0,5" Background="Transparent"
                          Tapped="Event_Tapped" Tag="{x:Bind ExecutionId}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind When}" FontSize="12" Opacity="0.75" VerticalAlignment="Center"/>
                        <FontIcon Grid.Column="1" Glyph="{x:Bind Glyph}" FontSize="14"
                                  Foreground="{x:Bind Brush}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Title}"/>
                            <TextBlock Text="{x:Bind Detail}" Opacity="0.6" FontSize="12"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Border Grid.Column="3" Background="{x:Bind ScoreBrush}" CornerRadius="4" Padding="6,2"
                                VerticalAlignment="Center" Visibility="{x:Bind ScoreVisibility}">
                            <TextBlock Text="{x:Bind Score}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
